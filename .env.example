# Application
APP_ENV=production
APP_DEBUG=false

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pluggedin_itdbadm
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_CONNECT_TIMEOUT=10

# External MySQL SSL (optional, useful for Aiven)
# Set either DB_SSL_CA to an absolute path inside the container
# or DB_SSL_CA_BASE64 to the base64-encoded CA certificate contents.
DB_SSL_CA=
DB_SSL_CA_BASE64=
DB_SSL_CERT=
DB_SSL_CERT_BASE64=
DB_SSL_KEY=
DB_SSL_KEY_BASE64=
DB_SSL_CIPHER=
DB_SSL_VERIFY_SERVER_CERT=true

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
